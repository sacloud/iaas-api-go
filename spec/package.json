{
  "name": "@sacloud/iaas-api-spec",
  "version": "0.0.1",
  "private": true,
  "description": "TypeSpec definitions for sacloud IaaS API",
  "scripts": {
    "build": "pnpm run generate && pnpm run format && pnpm run lint && pnpm run generate:client",
    "generate": "(cd .. && go run ./internal/tools/gen-typespec/) && pnpm run copy:main",
    "generate:client": "find ../iaas/client -name '*.go' -delete; ogen --target ../iaas/client --package client --config ogen.yml tsp-output/@typespec/openapi3/openapi.yaml",
    "copy:main": "cp src/main.tsp typespec/main.tsp",
    "format": "tsp format typespec/",
    "lint": "tsp compile typespec/main.tsp",
    "redocly": "redocly build-docs tsp-output/@typespec/openapi3/openapi.yaml -o redoc-static.html && open redoc-static.html"
  },
  "devDependencies": {
    "@redocly/cli": "^2.26.0"
  },
  "dependencies": {
    "@typespec/compiler": "^1.11.0",
    "@typespec/http": "^1.11.0",
    "@typespec/openapi3": "^1.11.0"
  }
}
